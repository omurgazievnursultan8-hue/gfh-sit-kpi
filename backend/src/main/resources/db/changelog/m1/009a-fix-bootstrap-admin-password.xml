<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
      Original 009 hash did not match the documented default password "Admin123!@#"
      (CLAUDE.md). This changeset corrects the bootstrap admin hash for both fresh
      installs (where 009 just inserted the broken hash) and existing deployments
      that still have the original placeholder.
    -->
    <changeSet id="009a-fix-bootstrap-admin-password" author="gfh" runOnChange="false">
        <update tableName="users">
            <column name="password_hash" value="$2b$12$/a6Ei.xdefOGCcVW/aHcUOh0oGtGSDvNsJTtDt4NMgxzteDiwxBwG"/>
            <column name="password_updated_at" valueComputed="CURRENT_TIMESTAMP"/>
            <where>email = 'admin@gfh.kg' AND password_hash = '$2a$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewdBPj/oW/3gkku6'</where>
        </update>
    </changeSet>
</databaseChangeLog>
