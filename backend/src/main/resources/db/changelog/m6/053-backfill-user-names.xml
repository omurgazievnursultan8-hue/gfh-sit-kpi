<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
      Backfill split name fields from full_name (Russian convention: Фамилия Имя Отчество).
      Only rows where all three split fields are still NULL — manual edits preserved.
    -->
    <changeSet id="053-backfill-user-names" author="gfh">
        <sql splitStatements="false"><![CDATA[
            UPDATE users
            SET
                last_name   = COALESCE(last_name,   split_part(full_name, ' ', 1)),
                first_name  = COALESCE(first_name,  NULLIF(split_part(full_name, ' ', 2), '')),
                middle_name = COALESCE(
                    middle_name,
                    NULLIF(
                        regexp_replace(
                            full_name,
                            '^\s*\S+\s+\S+\s*',
                            ''
                        ),
                        ''
                    )
                )
            WHERE full_name IS NOT NULL
              AND last_name IS NULL
              AND first_name IS NULL
              AND middle_name IS NULL;
        ]]></sql>
    </changeSet>
</databaseChangeLog>
