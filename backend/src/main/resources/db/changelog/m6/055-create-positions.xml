<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="055-create-positions" author="gfh">
        <createTable tableName="positions">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name_ru" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name_kg" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="unit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(32)"/>
            <column name="display_order" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="positions" baseColumnNames="unit_id"
                                 constraintName="fk_positions_unit"
                                 referencedTableName="org_units" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createIndex tableName="positions" indexName="idx_positions_unit">
            <column name="unit_id"/>
        </createIndex>
        <createIndex tableName="positions" indexName="idx_positions_unit_order">
            <column name="unit_id"/>
            <column name="display_order"/>
        </createIndex>

        <addColumn tableName="users">
            <column name="position_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="users" baseColumnNames="position_id"
                                 constraintName="fk_users_position"
                                 referencedTableName="positions" referencedColumnNames="id"
                                 onDelete="SET NULL"/>

        <createIndex tableName="users" indexName="idx_users_position">
            <column name="position_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
